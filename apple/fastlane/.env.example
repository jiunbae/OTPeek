# Copy to `apple/fastlane/.env` and fill in. NEVER commit the real .env or the .p8 key.
#
# Get these from App Store Connect → Users and Access → Integrations (App Store Connect API):
#   - ASC_KEY_ID    : the Key ID of the API key you generated (matches AuthKey_<KEY_ID>.p8)
#   - ASC_ISSUER_ID : the Issuer ID shown at the top of that page (a UUID)
#
# The .p8 key files already present on this machine:
#   ~/.appstoreconnect/private_keys/AuthKey_DM2DR93KV5.p8
#   ~/.appstoreconnect/private_keys/AuthKey_T75A5FYM6V.p8

ASC_KEY_ID=DM2DR93KV5
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
# ASC_KEY_FILEPATH=/Users/jiun/.appstoreconnect/private_keys/AuthKey_DM2DR93KV5.p8
