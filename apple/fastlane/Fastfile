require "fileutils"

# fastlane Fastfile — OTPeek App Store pipeline (macOS + iOS).
#
# Auth: App Store Connect API key (no interactive 2FA). Provide via env / .env:
#   ASC_KEY_ID        e.g. DM2DR93KV5   (the AuthKey_<KEY_ID>.p8 in ~/.appstoreconnect/private_keys)
#   ASC_ISSUER_ID     the Issuer ID (UUID) — App Store Connect → Users and Access → Integrations
#   ASC_KEY_FILEPATH  optional; defaults to ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
#
# One-time:   fastlane ios create_app        # creates the ASC app record
# Release:    fastlane mac release           # build → sign → upload (macOS)
#             fastlane ios release           # build → sign → upload (iOS / TestFlight)

APP_IDENTIFIER = "com.otpeek.app"
APP_NAME       = "OTPeek"
XCODEPROJ      = "Otpeek.xcodeproj"
MAC_INSTALLER_CERT = "3rd Party Mac Developer Installer: Jiun Bae (728FW73BS8)"

# Build the App Store Connect API key object AND export the SPACESHIP_CONNECT_API_*
# env vars, so both api_key-aware actions (build/upload) and the legacy `produce`
# action authenticate via the API key (no interactive 2FA).
def asc_api_key
  key_id = ENV.fetch("ASC_KEY_ID") { UI.user_error!("Set ASC_KEY_ID (see fastlane/.env.example)") }
  issuer = ENV.fetch("ASC_ISSUER_ID") { UI.user_error!("Set ASC_ISSUER_ID (see fastlane/.env.example)") }
  path   = ENV["ASC_KEY_FILEPATH"] ||
           File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")
  UI.user_error!("API key not found at #{path}") unless File.exist?(path)
  ENV["SPACESHIP_CONNECT_API_KEY_ID"]       = key_id
  ENV["SPACESHIP_CONNECT_API_ISSUER_ID"]    = issuer
  ENV["SPACESHIP_CONNECT_API_KEY_FILEPATH"] = path
  app_store_connect_api_key(key_id: key_id, issuer_id: issuer, key_filepath: path)
end

# Ensure the Rust core xcframework + Swift bindings exist, and the project is fresh.
def prepare_project
  sh("cd .. && ./scripts/build-core.sh") unless File.directory?("../Frameworks/OtpeekCore.xcframework")
  sh("cd .. && xcodegen generate")
end

# CI/release machines may use a dedicated keychain, while a developer Mac can
# use its already-unlocked login keychain. Never keep the keychain password in
# source control.
def release_keychain_path
  ENV["OTPEEK_KEYCHAIN_PATH"] || File.expand_path("~/Library/Keychains/otpeek-build.keychain-db")
end

def unlock_release_keychain_if_present
  path = release_keychain_path
  return unless File.exist?(path)

  password = ENV["OTPEEK_KEYCHAIN_PASSWORD"]
  UI.user_error!("Set OTPEEK_KEYCHAIN_PASSWORD to unlock #{path}") if password.to_s.empty?
  unlock_keychain(path: path, password: password, add_to_search_list: true, set_default: false)
end

before_all do
  ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
end

platform :ios do
  desc "One-time: create the App Store Connect record for OTPeek"
  # NOTE: App Store Connect does NOT allow creating the app *record* via an API
  # key — `produce` falls back to Apple-ID + 2FA login. The bundle IDs are already
  # registered via the ASC API; the app record is a one-time manual step below.
  lane :create_app do
    UI.important("Bundle IDs are registered: #{APP_IDENTIFIER} + #{APP_IDENTIFIER}.widget")
    UI.important("Create the app record once (needs your interactive 2FA login):")
    UI.important("  https://appstoreconnect.apple.com → Apps → + → New App")
    UI.important("  Platforms: iOS + macOS · Name: #{APP_NAME} · Bundle ID: #{APP_IDENTIFIER} · SKU: otpeek-ios-macos")
    UI.important("Then: fastlane mac release  /  fastlane ios release")
  end

  desc "Build, sign, and upload the iOS build to App Store Connect / TestFlight"
  lane :release do
    api_key = asc_api_key
    unlock_release_keychain_if_present
    prepare_project
    build_app(
      project: XCODEPROJ,
      scheme: "Otpeek-iOS",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.otpeek.app" => "OTPeek iOS AppStore",
          "com.otpeek.app.widget" => "OTPeek Widget iOS AppStore"
        }
      }
    )
    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: false,   # flip to true once metadata + screenshots are set in ASC
      precheck_include_in_app_purchases: false,
      force: true
    )
  end
end

platform :ios do
  desc "Push App Store screenshots from fastlane/screenshots"
  lane :upload_screenshots do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true
    )
  end

  desc "Push App Store text metadata (name, subtitle, description, keywords, URLs) from fastlane/metadata"
  lane :upload_metadata do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_app_version_update: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end
end

platform :mac do
  desc "Build, sign, and upload the macOS build to App Store Connect"
  lane :release do
    api_key = asc_api_key
    unlock_release_keychain_if_present
    prepare_project
    build_app(
      project: XCODEPROJ,
      scheme: "Otpeek-macOS",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      clean: true,
      skip_package_pkg: true,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.otpeek.app" => "OTPeek macOS AppStore 1784287691",
          "com.otpeek.app.widget" => "OTPeek Widget macOS AppStore 1784287697"
        }
      }
    )
    archive_path = lane_context[SharedValues::XCODEBUILD_ARCHIVE]
    app_path = File.join(archive_path, "Products/Applications/OTPeek.app")
    UI.user_error!("Archived macOS app not found at #{app_path}") unless File.directory?(app_path)
    keychain = release_keychain_path
    UI.user_error!("macOS installer keychain not found at #{keychain}") unless File.exist?(keychain)
    pkg_path = File.expand_path("../build/OTPeek.pkg", __dir__)
    FileUtils.mkdir_p(File.dirname(pkg_path))
    File.delete(pkg_path) if File.exist?(pkg_path)
    sh("productbuild", "--component", app_path, "/Applications",
       "--sign", MAC_INSTALLER_CERT, "--keychain", keychain, pkg_path)
    upload_to_testflight(
      api_key: api_key,
      pkg: pkg_path,
      app_identifier: APP_IDENTIFIER,
      app_platform: "osx",
      uses_non_exempt_encryption: false,
      skip_waiting_for_build_processing: false
    )
  end
end
