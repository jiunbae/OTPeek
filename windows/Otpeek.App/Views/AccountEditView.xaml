<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Otpeek.App.Views.AccountEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource OtpeekEditorSurfaceStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="3">
                    <TextBlock x:Name="TitleText"
                               Text="Add Account"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Your secret stays encrypted in the local vault."
                               Style="{StaticResource OtpeekDetailTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource OtpeekIconButtonStyle}"
                        ToolTipService.ToolTip="Close"
                        AutomationProperties.Name="Close account editor"
                        Click="OnCloseClick">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="9" Padding="0,0,10,0">
                    <TextBlock Text="ACCOUNT"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="4,0,0,0" />

                    <Border Style="{StaticResource OtpeekFormSectionStyle}">
                        <StackPanel Spacing="13">
                            <TextBox x:Name="IssuerTextBox"
                                     Style="{StaticResource OtpeekFieldStyle}"
                                     Header="Issuer"
                                     PlaceholderText="Google, GitHub, Microsoft…" />

                            <TextBox x:Name="AccountNameTextBox"
                                     Style="{StaticResource OtpeekFieldStyle}"
                                     Header="Account name *"
                                     PlaceholderText="user@example.com" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="SecretKeyTextBox"
                                         Style="{StaticResource OtpeekFieldStyle}"
                                         Header="Secret key (Base32) *"
                                         PlaceholderText="JBSWY3DPEHPK3PXP" />

                                <Button Grid.Column="1"
                                        Style="{StaticResource OtpeekIconButtonStyle}"
                                        VerticalAlignment="Bottom"
                                        Margin="8,0,0,0"
                                        ToolTipService.ToolTip="Generate a random secret key"
                                        AutomationProperties.Name="Generate random secret key"
                                        Click="OnGenerateKeyClick">
                                    <FontIcon Glyph="&#xE8EE;" FontSize="15" />
                                </Button>
                            </Grid>

                            <InfoBar x:Name="ValidationErrorBar"
                                     IsOpen="False"
                                     Severity="Error"
                                     IsClosable="False" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="ORGANIZATION"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="4,14,0,0" />

                    <Border Style="{StaticResource OtpeekFormSectionStyle}">
                        <StackPanel Spacing="13">
                            <ToggleSwitch x:Name="FavoriteToggle"
                                          Header="Favorite"
                                          OffContent="Not favorite"
                                          OnContent="Shown first" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="FolderComboBox"
                                          Header="Folder"
                                          HorizontalAlignment="Stretch"
                                          DisplayMemberPath="Name" />

                                <ComboBox x:Name="ColorComboBox"
                                          Grid.Column="1"
                                          Margin="10,0,0,0"
                                          Header="Color"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Blue" Tag="#0078D4" />
                                    <ComboBoxItem Content="Green" Tag="#34A853" />
                                    <ComboBoxItem Content="Orange" Tag="#F7630C" />
                                    <ComboBoxItem Content="Red" Tag="#E74856" />
                                    <ComboBoxItem Content="Purple" Tag="#8764B8" />
                                    <ComboBoxItem Content="Pink" Tag="#E3008C" />
                                    <ComboBoxItem Content="Teal" Tag="#00B7C3" />
                                    <ComboBoxItem Content="Brown" Tag="#8E562E" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="OTP OPTIONS"
                               Style="{StaticResource SectionHeaderStyle}"
                               Margin="4,14,0,0" />

                    <Border Style="{StaticResource OtpeekFormSectionStyle}">
                        <!-- SelectionChanged is attached after InitializeComponent in code-behind. -->
                        <Expander Header="Advanced options"
                                  IsExpanded="False"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch">
                            <StackPanel Spacing="12" Padding="0,10,0,0">
                                <ComboBox x:Name="TypeComboBox"
                                          Header="Type"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="TOTP (time-based)" Tag="Totp" />
                                    <ComboBoxItem Content="HOTP (counter-based)" Tag="Hotp" />
                                </ComboBox>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="AlgorithmComboBox"
                                              Header="Algorithm"
                                              SelectedIndex="0"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="SHA1" Tag="Sha1" />
                                        <ComboBoxItem Content="SHA256" Tag="Sha256" />
                                        <ComboBoxItem Content="SHA512" Tag="Sha512" />
                                    </ComboBox>

                                    <ComboBox x:Name="DigitsComboBox"
                                              Grid.Column="1"
                                              Margin="10,0,0,0"
                                              Header="Digits"
                                              SelectedIndex="0"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="6" Tag="6" />
                                        <ComboBoxItem Content="7" Tag="7" />
                                        <ComboBoxItem Content="8" Tag="8" />
                                    </ComboBox>
                                </Grid>

                                <NumberBox x:Name="PeriodNumberBox"
                                           Header="Period (seconds)"
                                           Value="30"
                                           Minimum="1"
                                           Maximum="3600"
                                           SpinButtonPlacementMode="Compact" />

                                <NumberBox x:Name="CounterNumberBox"
                                           Header="Counter"
                                           Minimum="0"
                                           Maximum="999999999"
                                           SpinButtonPlacementMode="Compact"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Fields marked * are required"
                           Style="{StaticResource OtpeekDetailTextStyle}"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Content="Cancel"
                        Margin="0,0,8,0"
                        Click="OnCancelClick" />

                <Button x:Name="SaveButton"
                        Grid.Column="2"
                        Content="Save Account"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnSaveClick" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
