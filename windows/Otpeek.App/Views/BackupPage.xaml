<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Otpeek.App.Views.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="32,24,32,48" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760" HorizontalAlignment="Stretch" Spacing="0">
            <TextBlock Text="Backup &amp; Restore"
                       Style="{StaticResource OtpeekPageTitleStyle}" />
            <TextBlock Text="Move your encrypted vault safely between devices without exposing account secrets."
                       Style="{StaticResource OtpeekPageSubtitleStyle}"
                       Margin="0,4,0,4" />

            <TextBlock Text="EXPORT" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource OtpeekSettingsCardStyle}">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48" Height="48" CornerRadius="14"
                                Background="{ThemeResource OtpeekAccentSoftBrush}">
                            <FontIcon Glyph="&#xE898;" FontSize="22"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="Create an encrypted backup"
                                       Style="{StaticResource OtpeekCardTitleStyle}" />
                            <TextBlock Text="Exports all accounts and folders as a password-protected .otpvault file."
                                       Style="{StaticResource OtpeekDetailTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <InfoBar Title="Keep the password safe"
                             Message="The backup cannot be opened or restored without its password."
                             Severity="Warning"
                             IsOpen="True"
                             IsClosable="False" />

                    <Button x:Name="ExportButton"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="Export Backup" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock Text="IMPORT" Style="{StaticResource SectionHeaderStyle}" />
            <Border Style="{StaticResource OtpeekSettingsCardStyle}">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48" Height="48" CornerRadius="14"
                                Background="{StaticResource SuccessSoftBrush}">
                            <FontIcon Glyph="&#xE896;" FontSize="22"
                                      Foreground="{StaticResource SuccessBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="Restore an encrypted vault"
                                       Style="{StaticResource OtpeekCardTitleStyle}" />
                            <TextBlock Text="Choose whether imported accounts are merged with or replace this vault."
                                       Style="{StaticResource OtpeekDetailTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <InfoBar x:Name="ImportInfoBar"
                             IsOpen="False"
                             IsClosable="True" />

                    <Border Style="{StaticResource OtpeekFormSectionStyle}">
                        <RadioButtons x:Name="ImportModeRadioButtons"
                                      Header="Import mode"
                                      SelectedIndex="0">
                            <RadioButton x:Name="MergeImportRadio"
                                         Content="Merge — keep current accounts and add or update from the backup" />
                            <RadioButton Content="Replace — remove the current vault and restore only the backup" />
                        </RadioButtons>
                    </Border>

                    <TextBlock Text="Merge is recommended. Replace removes accounts and folders that are not present in the backup."
                               Style="{StaticResource OtpeekDetailTextStyle}" />

                    <Button x:Name="ImportButton" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B5;" FontSize="14" />
                            <TextBlock Text="Import Backup" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
