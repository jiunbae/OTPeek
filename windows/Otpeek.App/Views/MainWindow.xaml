<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Otpeek.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Otpeek.App.Views"
    Title="OTPeek">

    <Grid Background="Transparent">
        <NavigationView x:Name="NavigationViewControl"
                        Background="Transparent"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        AlwaysShowHeader="False"
                        PaneDisplayMode="Left"
                        OpenPaneLength="248"
                        CompactPaneLength="48">

            <NavigationView.MenuItems>
                <!-- Keep the high-frequency actions in the sidebar, matching macOS. -->
                <NavigationViewItemHeader Content="Quick Actions" />
                <NavigationViewItem x:Name="ImportQrNavItem"
                                    Content="Import QR Image"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xED14;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="AddAccountNavItem"
                                    Content="Add Manually"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE710;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="PasteUriNavItem"
                                    Content="Paste from Clipboard"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Library" />
                <NavigationViewItem x:Name="AllAccountsNavItem"
                                    Content="All Accounts"
                                    Tag="accounts">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="FavoritesNavItem"
                                    Content="Favorites"
                                    Tag="favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE735;" Foreground="{StaticResource FavoriteBrush}" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="UncategorizedNavItem"
                                    Content="Uncategorized"
                                    Tag="uncategorized">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Folders" />
                <!-- Folder items are inserted here at runtime. -->

                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Tools" />
                <NavigationViewItem Content="Backup &amp; Restore" Tag="backup">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="AddFolderNavItem"
                                    Content="New Folder"
                                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F4;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <NavigationView.PaneFooter>
                <StackPanel Margin="8,8,8,4" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE72E;"
                                  FontSize="11"
                                  Foreground="{ThemeResource OtpeekSecondaryTextBrush}" />
                        <TextBlock Text="Encrypted on this device"
                                   Style="{StaticResource OtpeekDetailTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.Content>
                <Border Background="{ThemeResource OtpeekWindowBrush}"
                        BorderBrush="{ThemeResource OtpeekStrokeBrush}"
                        BorderThickness="1,0,0,0"
                        CornerRadius="12,0,0,0">
                    <Frame x:Name="ContentFrame" />
                </Border>
            </NavigationView.Content>
        </NavigationView>

        <!-- Editor is modal but remains in the same window and theme context. -->
        <Grid x:Name="EditOverlay"
              Canvas.ZIndex="10"
              Visibility="Collapsed"
              Background="{ThemeResource OtpeekOverlayBrush}">
            <local:AccountEditView x:Name="AccountEditView"
                                   Width="520"
                                   MaxHeight="620"
                                   Margin="24"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
