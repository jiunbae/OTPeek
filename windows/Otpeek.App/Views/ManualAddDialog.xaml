<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Otpeek.App.Views.ManualAddDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Account Manually"
    PrimaryButtonText="Add"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False">

    <StackPanel Spacing="16" MinWidth="400">
        <!-- Status Message -->
        <InfoBar x:Name="StatusInfoBar"
                 IsOpen="True"
                 IsClosable="False"
                 Severity="Informational"
                 Message="Enter account details below" />

        <!-- Manual Entry Form -->
        <StackPanel Spacing="12">
            <!-- Service Name (Issuer) -->
            <TextBox x:Name="IssuerTextBox"
                     Header="Service Name"
                     PlaceholderText="e.g., Google, GitHub, Microsoft" />

            <!-- Account Name -->
            <TextBox x:Name="AccountNameTextBox"
                     Header="Account Name *"
                     PlaceholderText="e.g., user@example.com" />

            <!-- Secret Key -->
            <TextBox x:Name="SecretKeyTextBox"
                     Header="Secret Key (Base32) *"
                     PlaceholderText="e.g., JBSWY3DPEHPK3PXP" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="FolderCombo"
                          Grid.Column="0"
                          Header="Folder"
                          HorizontalAlignment="Stretch" />

                <ComboBox x:Name="ColorCombo"
                          Grid.Column="1"
                          Header="Color"
                          HorizontalAlignment="Stretch"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Blue" Tag="#0078D4" />
                    <ComboBoxItem Content="Green" Tag="#34A853" />
                    <ComboBoxItem Content="Orange" Tag="#F7630C" />
                    <ComboBoxItem Content="Red" Tag="#E74856" />
                    <ComboBoxItem Content="Purple" Tag="#8764B8" />
                    <ComboBoxItem Content="Pink" Tag="#E3008C" />
                    <ComboBoxItem Content="Teal" Tag="#00B7C3" />
                    <ComboBoxItem Content="Brown" Tag="#8E562E" />
                </ComboBox>
            </Grid>

            <ToggleSwitch x:Name="FavoriteToggle"
                          Header="Add to Favorites"
                          OffContent="No"
                          OnContent="Yes" />

            <!-- Type and Algorithm Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- OTP Type -->
                <ComboBox x:Name="OtpTypeCombo"
                          Grid.Column="0"
                          Header="Type"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,6,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="Time-based (TOTP)" Tag="totp" />
                    <ComboBoxItem Content="Counter-based (HOTP)" Tag="hotp" />
                </ComboBox>

                <!-- Algorithm -->
                <ComboBox x:Name="AlgorithmCombo"
                          Grid.Column="1"
                          Header="Algorithm"
                          HorizontalAlignment="Stretch"
                          Margin="6,0,0,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="SHA1" Tag="SHA1" />
                    <ComboBoxItem Content="SHA256" Tag="SHA256" />
                    <ComboBoxItem Content="SHA512" Tag="SHA512" />
                </ComboBox>
            </Grid>

            <!-- Digits and Period/Counter Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Digits -->
                <ComboBox x:Name="DigitsCombo"
                          Grid.Column="0"
                          Header="Digits"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,6,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="6 digits" Tag="6" />
                    <ComboBoxItem Content="7 digits" Tag="7" />
                    <ComboBoxItem Content="8 digits" Tag="8" />
                </ComboBox>

                <!-- Period (TOTP) or Counter (HOTP) -->
                <NumberBox x:Name="PeriodNumberBox"
                           Grid.Column="1"
                           Header="Period (seconds)"
                           HorizontalAlignment="Stretch"
                           Margin="6,0,0,0"
                           Value="30"
                           Minimum="10"
                           Maximum="120"
                           SpinButtonPlacementMode="Compact" />
            </Grid>

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel HorizontalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="PreviewCodeText"
                               Text="------"
                               Style="{StaticResource OtpCodeTextStyle}" />
                    <TextBlock x:Name="PreviewCaptionText"
                               Text="Live preview"
                               HorizontalAlignment="Center"
                               FontSize="11"
                               Opacity="0.65" />
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</ContentDialog>
