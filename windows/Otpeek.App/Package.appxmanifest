<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  IgnorableNamespaces="uap uap3 uap5 rescap com">

  <Identity
    Name="Otpeek"
    Publisher="CN=Otpeek"
    Version="2.0.1.0" />

  <mp:PhoneIdentity PhoneProductId="12345678-1234-1234-1234-123456789012" PhonePublisherId="00000000-0000-0000-0000-000000000000"/>

  <Properties>
    <DisplayName>OTPeek</DisplayName>
    <PublisherDisplayName>OTPeek</PublisherDisplayName>
    <Logo>Assets\Logo\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US"/>
    <Resource Language="ko-KR"/>
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="$targetnametoken$.exe"
      EntryPoint="$targetentrypoint$">

      <uap:VisualElements
        DisplayName="OTPeek"
        Description="Secure one-time password authenticator for Windows"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Logo\Square150x150Logo.png"
        Square44x44Logo="Assets\Logo\Square44x44Logo.png">
        <uap:DefaultTile
          ShortName="OTPeek"
          Wide310x150Logo="Assets\Logo\Wide310x150Logo.png" />
        <uap:SplashScreen
          Image="Assets\Logo\SplashScreen.png"
          BackgroundColor="#151519" />
      </uap:VisualElements>

      <Extensions>
        <!-- Startup Task -->
        <uap5:Extension Category="windows.startupTask">
          <uap5:StartupTask
            TaskId="OtpAuthStartup"
            Enabled="false"
            DisplayName="OTPeek" />
        </uap5:Extension>

        <!-- Protocol Handler (otpauth://) — industry-standard Key URI scheme -->
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="otpauth">
            <uap:DisplayName>OTPeek OTP Auth Link</uap:DisplayName>
          </uap:Protocol>
        </uap:Extension>

        <!-- App deep-link scheme (otpeek://add?uri=... / otpeek://totp/...) -->
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="otpeek">
            <uap:DisplayName>OTPeek Link</uap:DisplayName>
          </uap:Protocol>
        </uap:Extension>

        <!-- File Type Association (.otpvault backup/restore) -->
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="otpvault">
            <uap:DisplayName>OTPeek Encrypted Vault</uap:DisplayName>
            <uap:Logo>Assets\Logo\Square44x44Logo.png</uap:Logo>
            <uap:SupportedFileTypes>
              <uap:FileType>.otpvault</uap:FileType>
            </uap:SupportedFileTypes>
          </uap:FileTypeAssociation>
        </uap:Extension>

        <!-- COM Server for Widget Provider -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:ExeServer Executable="Otpeek.Widget.exe" Arguments="-RegisterProcessAsComServer" DisplayName="OTPeek Widget Provider">
              <com:Class Id="8A2C4E6F-1B3D-5A7C-9E0F-2D4B6C8A0E1F" DisplayName="OTPeek Widget Provider" />
            </com:ExeServer>
          </com:ComServer>
        </com:Extension>

        <!-- Widget Provider Registration -->
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension Name="com.microsoft.windows.widgets"
                             DisplayName="OTPeek"
                             Id="OtpWidget"
                             PublicFolder="Public">
            <uap3:Properties>
              <WidgetProvider>
                <ProviderIcons>
                  <Icon Path="Assets\Logo\StoreLogo.png" />
                </ProviderIcons>
                <Activation>
                  <CreateInstance ClassId="8A2C4E6F-1B3D-5A7C-9E0F-2D4B6C8A0E1F" />
                </Activation>
                <Definitions>
                  <Definition Id="OtpWidget"
                              DisplayName="OTP Code"
                              Description="Show an OTP code. Copy it or move between accounts."
                              AllowMultiple="true">
                    <Capabilities>
                      <Capability>
                        <Size Name="small" />
                      </Capability>
                      <Capability>
                        <Size Name="medium" />
                      </Capability>
                      <Capability>
                        <Size Name="large" />
                      </Capability>
                    </Capabilities>
                    <ThemeResources>
                      <Icons>
                        <Icon Path="Assets\Logo\StoreLogo.png" />
                      </Icons>
                      <Screenshots>
                        <Screenshot
                          Path="Assets\Widget\WidgetScreenshot.png"
                          DisplayAltText="OTPeek one-time password code widget preview" />
                      </Screenshots>
                      <DarkMode>
                        <Icons>
                          <Icon Path="Assets\Logo\StoreLogo.png" />
                        </Icons>
                        <Screenshots>
                          <Screenshot
                            Path="Assets\Widget\WidgetScreenshotDark.png"
                            DisplayAltText="OTPeek one-time password code widget in dark mode" />
                        </Screenshots>
                      </DarkMode>
                      <LightMode>
                        <Icons>
                          <Icon Path="Assets\Logo\StoreLogo.png" />
                        </Icons>
                        <Screenshots>
                          <Screenshot
                            Path="Assets\Widget\WidgetScreenshotLight.png"
                            DisplayAltText="OTPeek one-time password code widget in light mode" />
                        </Screenshots>
                      </LightMode>
                    </ThemeResources>
                  </Definition>
                </Definitions>
              </WidgetProvider>
            </uap3:Properties>
          </uap3:AppExtension>
        </uap3:Extension>
      </Extensions>

    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <Capability Name="internetClient" />
    <uap:Capability Name="userAccountInformation"/>
  </Capabilities>
</Package>
